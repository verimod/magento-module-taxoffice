<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- Layout processors -->
    <type name="Magento\Checkout\Block\Checkout\LayoutProcessor">
        <plugin name="verimod_taxoffice_checkout_layout" type="Verimod\TaxOffice\Plugin\CheckoutLayoutProcessorPlugin"/>
    </type>

    <!-- Customer address management -->
    <type name="Magento\Customer\Api\AddressRepositoryInterface">
        <plugin name="verimod_taxoffice_address_repository" type="Verimod\TaxOffice\Plugin\AddressRepositoryPlugin"/>
    </type>

    <!-- Preference for address model -->
    <type name="Magento\Customer\Model\Address">
        <plugin name="verimod_taxoffice_address_model" type="Verimod\TaxOffice\Plugin\AddressModelPlugin"/>
    </type>
</config>